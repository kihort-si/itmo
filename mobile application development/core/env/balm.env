DATABASE_URL = "jdbc:postgresql://core-postgres:5432/mobiles_core"
DATABASE_USER = "mobiles_core_user"
DATABASE_PASSWORD = "mobiles_core_pass"

RABBITMQ_HOST = rabbit
RABBITMQ_PORT = 5672
RABBITMQ_VHOST = /balm
RABBITMQ_USER = admin
RABBITMQ_PASSWORD = admin

API_GATEWAY_URL = "http://core-nginx:8050"

ATTRIBUTE_CHANGE_NTF_QUEUE = "clients.attribute.ntf.balm"
REPORT_REQUEST_EXCHANGE = "balm.reports.daily"
REFS_SYNC_REQUIRED = true

REPORT_SCHEDULING_ENABLED = true