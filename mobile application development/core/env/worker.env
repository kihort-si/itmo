TEMPORAL_HOST_PORT=temporal:7233
TASK_QUEUE=core-worker-queue
API_GATEWAY_URL=http://core-nginx:8050
RABBITMQ_URL=amqp://admin:admin@rabbit:5672/%2Fworker
MAIL_EXCHANGE=worker.mails
MAIL_AMQP_BASE_TYPE=report
MAIL_AMQP_SUCCESS_REPORT_TYPE=SUCCESSFULL_REGISTRATION_EMAIL
MAIL_AMQP_FAILURE_REPORT_TYPE=FAILED_REGISTRATION_EMAIL